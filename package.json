{
  "name": "@substate/workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source monorepo for Substate packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dumitru-arsenii/substate.git"
  },
  "homepage": "https://github.com/dumitru-arsenii/substate#readme",
  "bugs": {
    "url": "https://github.com/dumitru-arsenii/substate/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "dev": "pnpm -r --parallel dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.1.1"
  }
}
